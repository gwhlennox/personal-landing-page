---
import '../styles/global.css';

const posts = await Astro.glob('./posts/*.md');
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Articles — George Lennox</title>
    <meta name="description" content="Writing by George Lennox on partnerships, operations, Web3, and enterprise strategy." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>

  <body>

    <nav class="nav">
      <div class="maintenance-banner">Under construction — check back soon</div>
      <div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="Back to home">
          <img src="/headshot.jpg" alt="George Lennox" class="nav-avatar" width="30" height="30" />
        </a>
        <div class="nav-links">
          <a href="/#experience">Experience</a>
          <a href="/media">Media</a>
          <a href="/#about">About</a>
          <a href="/#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <div class="standalone-page">

        <a href="/" class="back-link">← Home</a>

        <header class="standalone-header">
          <p class="hero-label">Writing</p>
          <h1 class="standalone-title">Articles</h1>
          <p class="standalone-subtitle">On partnerships, operations, Web3, and enterprise strategy.</p>
        </header>

        {sortedPosts.length > 0 ? (
          <ul class="posts-list">
            {sortedPosts.map((post) => (
              <li class="post-item">
                <span class="post-item-date">
                  {new Date(post.frontmatter.date).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                </span>
                <div class="post-item-body">
                  <a href={post.url} class="post-item-title">{post.frontmatter.title}</a>
                  {post.frontmatter.description && (
                    <p class="post-item-desc">{post.frontmatter.description}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <p class="posts-empty">Articles coming soon.</p>
        )}

      </div>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <a href="/" class="footer-home">← George Lennox</a>
        <span>© 2026</span>
      </div>
    </footer>

  </body>
</html>
