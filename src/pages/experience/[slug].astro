---
import '../../styles/global.css';
import { experience } from '../../data/experience.js';
import Footer from '../../components/Footer.astro';
import AuthGate from '../../components/AuthGate.astro';

export function getStaticPaths() {
  return experience.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{item.company} — George Lennox</title>
    <meta name="description" content={`George Lennox at ${item.company} — ${item.role}. ${item.companySummary}`} />
    <link rel="canonical" href={`https://georgelennox.xyz/experience/${item.slug}`} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://georgelennox.xyz/experience/${item.slug}`} />
    <meta property="og:title" content={`${item.company} — George Lennox`} />
    <meta property="og:description" content={`George Lennox at ${item.company} — ${item.role}. ${item.companySummary}`} />
    <meta property="og:image" content="https://georgelennox.xyz/headshot.jpg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@winwithgeorge" />
    <meta name="twitter:title" content={`${item.company} — George Lennox`} />
    <meta name="twitter:description" content={`George Lennox at ${item.company} — ${item.role}.`} />
    <meta name="twitter:image" content="https://georgelennox.xyz/headshot.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>

  <body>
    <AuthGate />
    <nav class="nav">
<div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="Back to home">
          <img src="/headshot.jpg" alt="George Lennox" class="nav-avatar" width="30" height="30" />
        </a>
        <div class="nav-links">
          <a href="/#experience">Experience</a>
          <a href="/media">Media</a>
          <a href="/#about">About</a>
          <a href="/#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <div class="company-page">

        <a href="/#experience" class="back-link">← Back to experience</a>

        <header class="company-header">
          <div>
            <p class="hero-label">{item.role}</p>
            <div class="company-name-row">
              {item.logo && (
                <img
                  src={item.logo}
                  alt={`${item.company} logo`}
                  class="company-logo"
                  onerror="this.style.display='none'"
                  width="32"
                  height="32"
                />
              )}
              <h1 class="company-name">{item.company}</h1>
            </div>
            <p class="company-period">{item.period}</p>
          </div>
          <a
            href={item.website}
            target="_blank"
            rel="noopener noreferrer"
            class="company-website-link"
          >
            Visit website ↗
          </a>
        </header>

        <div class="company-meta">
          <div class="company-meta-item">
            <span class="meta-label">Headcount</span>
            <span class="meta-value">{item.headcount}</span>
          </div>
          <div class="company-meta-item">
            <span class="meta-label">Team</span>
            <span class="meta-value">{item.teamSize}</span>
          </div>
        </div>

        <section class="section">
          <h2 class="section-label">About {item.company}</h2>
          <p class="company-body">{item.companySummary}</p>
        </section>

        <section class="section">
          <h2 class="section-label">Role Overview</h2>
          <ul class="role-bullets">
            {item.bullets.map((bullet) => (
              <li class="role-bullet">{bullet}</li>
            ))}
          </ul>
        </section>

        {item.notablePartners && item.notablePartners.length > 0 && (
          <section class="section">
            <h2 class="section-label">Notable Partners</h2>
            <div class="skills-tags">
              {item.notablePartners.map((partner) => (
                <span class="skill-tag">{partner}</span>
              ))}
            </div>
          </section>
        )}


      </div>
    </main>

    <Footer />

  </body>
</html>
