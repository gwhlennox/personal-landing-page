---
import '../styles/global.css';
import { experience } from '../data/experience.js';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>George Lennox</title>
    <meta name="description" content="George Lennox — Strategic Partnerships & Operations Leader | Fintech, Crypto and Enterprise SaaS" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>

  <body>

    <nav class="nav">
      <div class="maintenance-banner">Under construction — check back soon</div>
      <div class="nav-inner">
        <a href="#" class="nav-logo" aria-label="Home">
          <img src="/headshot.jpg" alt="George Lennox" class="nav-avatar" width="30" height="30" />
        </a>
        <div class="nav-links">
          <a href="#experience">Experience</a>
          <a href="/media">Media</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="container">

      <!-- Hero -->
      <section class="hero">
        <div class="hero-content">
          <p class="hero-label">Strategic Partnerships &amp; Operations Leader</p>
          <h1 class="hero-name">George<br />Lennox</h1>
          <p class="hero-bio">
            10+ years building partnerships, scaling operations, and driving
            transformation across enterprise SaaS, Web3, and fintech.
          </p>
          <a href="#about" class="read-more">Read more →</a>
          <div class="contact-pills">
            <a href="mailto:gwhlennox@gmail.com" class="contact-pill" aria-label="Email">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              Email
            </a>
            <a href="https://www.linkedin.com/in/georgelennox/" target="_blank" rel="noopener noreferrer" class="contact-pill" aria-label="LinkedIn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href="https://wa.me/447792304894" target="_blank" rel="noopener noreferrer" class="contact-pill" aria-label="WhatsApp">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
            <a href="/george-lennox-cv.pdf" download class="contact-pill" aria-label="Download CV">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download CV
            </a>
            <!-- TODO: update Telegram username when it changes -->
            <a href="https://t.me/devmetalguy" target="_blank" rel="noopener noreferrer" class="contact-pill" aria-label="Telegram">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
              Telegram
            </a>
          </div>
        </div>
        <img
          src="/headshot.jpg"
          alt="George Lennox"
          class="hero-photo"
          width="200"
          height="267"
        />
      </section>

      <!-- Experience -->
      <section id="experience" class="section">
        <h2 class="section-label">Experience</h2>
        <div class="portfolio-grid">
          {experience.map((item) => (
            <article class="card">
              <div class="card-header">
                <h3 class="card-company">{item.company}</h3>
                <span class="card-period">{item.period}</span>
              </div>
              <p class="card-role">{item.role}</p>
              <p class="card-desc">{item.description}</p>
              {item.caseStudies && item.caseStudies.length > 0 && (
                <div class="card-projects">
                  <p class="card-projects-label">Case Studies</p>
                  <ul class="card-projects-list">
                    {item.caseStudies.map((cs) => (
                      <li class="card-project-item">{cs.name}</li>
                    ))}
                  </ul>
                </div>
              )}
              <div class="card-footer">
                <a href={`/experience/${item.slug}`} class="card-arrow" aria-label={`View ${item.company} in detail`}>
                  View more →
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section id="skills" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Skills</h2>
          </div>
          <div class="skills-tags">
            <span class="skill-tag">Strategic Partnerships & Ecosystem Growth</span>
            <span class="skill-tag">Customer Success & Client Retention</span>
            <span class="skill-tag">AI Adoption & Workflow Automation</span>
            <span class="skill-tag">Executive Operations & Chief of Staff</span>
            <span class="skill-tag">Data Analytics & Executive Reporting</span>
            <span class="skill-tag">Programme & Portfolio Leadership</span>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">About</h2>
          </div>
          <div class="about-text">
            <p>
              I have over 10 years of experience leading customer relationships,
              strategic initiatives, and transformation programmes across fintech,
              Web3, and enterprise technology.
            </p>
            <p>
              Most recently, I led strategic partnerships and ecosystem growth at
              SideShift.ai. Prior to that, I served as Chief of Staff to programme
              leadership at Accenture on a major FTSE 100 transformation programme
              for Kingfisher Group, acting as the bridge between executive stakeholders
              and delivery teams.
            </p>
            <p>
              My background combines customer success, partnerships, programme
              leadership, and enterprise consulting — with a strong track record of
              growing accounts, delivering complex initiatives, and building trusted
              stakeholder relationships.
            </p>
            <p>Based in London, UK. Open to remote and hybrid opportunities.</p>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Contact</h2>
          </div>
          <div class="sidebar-body">
            <p>Open to new opportunities, collaborations, and conversations.</p>
            <nav class="contact-links" aria-label="Contact links">
              <a href="mailto:gwhlennox@gmail.com">gwhlennox@gmail.com</a>
              <a href="https://www.linkedin.com/in/georgelennox/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
              <a href="https://linktr.ee/georgelennox" target="_blank" rel="noopener noreferrer">Linktree ↗</a>
            </nav>
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>© 2026 George Lennox</span>
        <span>London, UK</span>
      </div>
    </footer>

  </body>
</html>
