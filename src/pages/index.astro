---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>George Lennox</title>
    <meta name="description" content="George Lennox — Customer Success & Chief of Staff | Fintech, Crypto and Enterprise SaaS" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>

  <body>

    <nav class="nav">
      <div class="nav-inner">
        <a href="#" class="nav-logo">GL</a>
        <div class="nav-links">
          <a href="#portfolio">Portfolio</a>
          <a href="#media">Media</a>
          <a href="#articles">Articles</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="container">

      <!-- Hero -->
      <section class="hero">
        <p class="hero-label">Customer Success &amp; Chief of Staff</p>
        <h1 class="hero-name">George<br />Lennox</h1>
        <p class="hero-bio">
          Fintech, Crypto and Enterprise SaaS. Bridging strategy and execution
          at FTSE 100 companies. Based in Bangkok — open to remote &amp; hybrid.
        </p>
      </section>

      <!-- Portfolio -->
      <section id="portfolio" class="section">
        <h2 class="section-label">Portfolio</h2>
        <div class="portfolio-grid">
          {experience.map((item) => (
            <article class="card">
              <div class="card-header">
                <h3 class="card-company">{item.company}</h3>
                <span class="card-period">{item.period}</span>
              </div>
              <p class="card-role">{item.role}</p>
              <p class="card-desc">{item.description}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- Media -->
      <section id="media" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Media</h2>
          </div>
          <div class="sidebar-body">
            <p>
              Interviews, podcasts, and features across fintech, Web3,
              and enterprise strategy.
            </p>
            <a
              href="https://linktr.ee/georgelennox"
              target="_blank"
              rel="noopener noreferrer"
              class="link-arrow"
            >
              Explore media appearances ↗
            </a>
          </div>
        </div>
      </section>

      <!-- Articles -->
      <section id="articles" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Articles</h2>
          </div>
          <div class="sidebar-body">
            <p>
              Writing on customer success, chief of staff, Web3, and operating
              at the intersection of strategy and delivery.
            </p>
            <a
              href="https://linktr.ee/georgelennox"
              target="_blank"
              rel="noopener noreferrer"
              class="link-arrow"
            >
              Read all articles ↗
            </a>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">About</h2>
            <img
              src="/headshot.jpg"
              alt="George Lennox"
              class="headshot"
              width="88"
              height="88"
            />
          </div>
          <div class="about-text">
            <p>
              George has over 10 years of experience leading customer relationships,
              strategic initiatives, and transformation programmes across fintech,
              Web3, and enterprise technology.
            </p>
            <p>
              Most recently, he led strategic partnerships and ecosystem growth at
              SideShift.ai. Prior to that, he served as Chief of Staff to programme
              leadership at Accenture on a major FTSE 100 transformation programme
              for Kingfisher Group, acting as the bridge between executive stakeholders
              and delivery teams.
            </p>
            <p>
              His background combines customer success, partnerships, programme
              leadership, and enterprise consulting — with a strong track record of
              growing accounts, delivering complex initiatives, and building trusted
              stakeholder relationships.
            </p>
            <p>Based in Thailand. Open to remote and hybrid opportunities.</p>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Contact</h2>
          </div>
          <div class="sidebar-body">
            <p>Open to new opportunities, collaborations, and conversations.</p>
            <nav class="contact-links" aria-label="Contact links">
              <a href="mailto:gwhlennox@gmail.com">gwhlennox@gmail.com</a>
              <a href="https://www.linkedin.com/in/george--lennox/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
              <a href="https://linktr.ee/georgelennox" target="_blank" rel="noopener noreferrer">Linktree ↗</a>
            </nav>
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>© 2026 George Lennox</span>
        <span>Bangkok, Thailand</span>
      </div>
    </footer>

  </body>
</html>
