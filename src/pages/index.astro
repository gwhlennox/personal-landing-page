<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>George Lennox</title>
    <meta name="description" content="George Lennox — Customer Success & Chief of Staff | Fintech, Crypto and Enterprise SaaS" />
    <link rel="icon" type="image/jpeg" href="/headshot.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet" />
    <style>
      html { scroll-behavior: smooth; }
    </style>
  </head>

  <body class="bg-white text-neutral-800 font-sans antialiased">

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-100">
      <div class="max-w-4xl mx-auto px-8 h-14 flex items-center justify-between">
        <a href="#" class="text-sm font-medium text-neutral-900 tracking-widest uppercase">GL</a>
        <div class="flex items-center gap-6 text-sm text-neutral-400">
          <a href="#portfolio" class="hover:text-neutral-900 transition-colors">Portfolio</a>
          <a href="#media" class="hover:text-neutral-900 transition-colors">Media</a>
          <a href="#articles" class="hover:text-neutral-900 transition-colors">Articles</a>
          <a href="#about" class="hover:text-neutral-900 transition-colors">About</a>
          <a href="#contact" class="hover:text-neutral-900 transition-colors">Contact</a>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-8">

      <!-- Hero -->
      <section class="pt-40 pb-24">
        <p class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">
          Customer Success &amp; Chief of Staff
        </p>
        <h1 class="text-6xl md:text-7xl font-light text-neutral-900 tracking-tight leading-none mb-8">
          George<br />Lennox
        </h1>
        <p class="text-base text-neutral-500 max-w-md leading-relaxed">
          Fintech, Crypto and Enterprise SaaS. Bridging strategy and execution at FTSE 100 companies.
          Based in Bangkok — open to remote &amp; hybrid.
        </p>
      </section>

      <!-- Portfolio -->
      <section id="portfolio" class="py-20 border-t border-neutral-100">
        <h2 class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-12">Portfolio</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {experience.map((item) => (
            <div class="border border-neutral-100 p-8 hover:border-neutral-300 hover:shadow-sm transition-all duration-300 group">
              <div class="flex items-start justify-between mb-4">
                <h3 class="text-lg font-medium text-neutral-900 group-hover:text-neutral-600 transition-colors">
                  {item.company}
                </h3>
                <span class="text-xs text-neutral-300 tabular-nums mt-1 shrink-0 ml-4">{item.period}</span>
              </div>
              <p class="text-xs uppercase tracking-wider text-neutral-400 mb-4">{item.role}</p>
              <p class="text-sm text-neutral-400 leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Media -->
      <section id="media" class="py-20 border-t border-neutral-100">
        <div class="md:grid md:grid-cols-3 md:gap-16">
          <div>
            <h2 class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Media</h2>
          </div>
          <div class="md:col-span-2">
            <p class="text-sm text-neutral-500 leading-relaxed mb-6">
              Interviews, podcasts, and features across fintech, Web3, and enterprise strategy.
            </p>
            <a
              href="https://linktr.ee/georgelennox"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-neutral-900 border-b border-neutral-200 pb-0.5 hover:border-neutral-900 transition-colors"
            >
              Explore media appearances ↗
            </a>
          </div>
        </div>
      </section>

      <!-- Articles -->
      <section id="articles" class="py-20 border-t border-neutral-100">
        <div class="md:grid md:grid-cols-3 md:gap-16">
          <div>
            <h2 class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Articles</h2>
          </div>
          <div class="md:col-span-2">
            <p class="text-sm text-neutral-500 leading-relaxed mb-6">
              Writing on customer success, chief of staff, Web3, and operating at the intersection of strategy and delivery.
            </p>
            <a
              href="https://linktr.ee/georgelennox"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-neutral-900 border-b border-neutral-200 pb-0.5 hover:border-neutral-900 transition-colors"
            >
              Read all articles ↗
            </a>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about" class="py-20 border-t border-neutral-100">
        <div class="md:grid md:grid-cols-3 md:gap-16">
          <div class="mb-8 md:mb-0">
            <h2 class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">About</h2>
            <img
              src="/headshot.jpg"
              alt="George Lennox"
              class="w-24 h-24 rounded-full object-cover object-top grayscale"
            />
          </div>
          <div class="md:col-span-2 space-y-4 text-sm text-neutral-500 leading-relaxed">
            <p>
              George has over 10 years of experience leading customer relationships, strategic initiatives,
              and transformation programmes across fintech, Web3, and enterprise technology.
            </p>
            <p>
              Most recently, he led strategic partnerships and ecosystem growth at SideShift.ai. Prior to
              that, he served as Chief of Staff to programme leadership at Accenture on a major FTSE 100
              transformation programme for Kingfisher Group, acting as the bridge between executive
              stakeholders and delivery teams.
            </p>
            <p>
              His background combines customer success, partnerships, programme leadership, and enterprise
              consulting — with a strong track record of growing accounts, delivering complex initiatives,
              and building trusted stakeholder relationships.
            </p>
            <p>Based in Thailand. Open to remote and hybrid opportunities.</p>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="py-20 border-t border-neutral-100">
        <div class="md:grid md:grid-cols-3 md:gap-16">
          <div>
            <h2 class="text-xs tracking-[0.3em] uppercase text-neutral-400 mb-6">Contact</h2>
          </div>
          <div class="md:col-span-2">
            <p class="text-sm text-neutral-500 leading-relaxed mb-8">
              Open to new opportunities, collaborations, and conversations.
            </p>
            <div class="flex flex-col gap-4">
              <a href="mailto:gwhlennox@gmail.com" class="text-sm text-neutral-900 hover:text-neutral-400 transition-colors">
                gwhlennox@gmail.com
              </a>
              <a href="https://www.linkedin.com/in/george--lennox/" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-900 hover:text-neutral-400 transition-colors">
                LinkedIn ↗
              </a>
              <a href="https://linktr.ee/georgelennox" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-900 hover:text-neutral-400 transition-colors">
                Linktree ↗
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="border-t border-neutral-100 mt-4">
      <div class="max-w-4xl mx-auto px-8 py-8 flex justify-between items-center text-xs text-neutral-300">
        <span>© 2026 George Lennox</span>
        <span>Bangkok, Thailand</span>
      </div>
    </footer>

