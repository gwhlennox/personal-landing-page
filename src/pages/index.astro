---
import '../styles/global.css';
import { experience } from '../data/experience.js';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>George Lennox</title>
    <meta name="description" content="George Lennox — Strategic Partnerships & Operations Leader | Fintech, Crypto and Enterprise SaaS" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>

  <body>

    <nav class="nav">
      <div class="maintenance-banner">Under construction — check back soon</div>
      <div class="nav-inner">
        <a href="#" class="nav-logo" aria-label="Home">
          <img src="/headshot.jpg" alt="George Lennox" class="nav-avatar" width="30" height="30" />
        </a>
        <div class="nav-links">
          <a href="#experience">Experience</a>
          <a href="/media">Media</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="container">

      <!-- Hero -->
      <section class="hero">
        <div class="hero-content">
          <p class="hero-label">Strategic Partnerships &amp; Operations Leader</p>
          <h1 class="hero-name">George<br />Lennox</h1>
          <p class="hero-bio">
            10+ years building partnerships, scaling operations, and driving
            transformation across enterprise SaaS, Web3, and fintech.
          </p>
          <a href="#about" class="read-more">Read more →</a>
          <div class="contact-pills">
            <a href="mailto:gwhlennox@gmail.com" class="contact-pill" aria-label="Email">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              Email
            </a>
            <a href="https://www.linkedin.com/in/georgelennox/" target="_blank" rel="noopener noreferrer" class="contact-pill" aria-label="LinkedIn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href="/george-lennox-cv.pdf" download class="contact-pill" aria-label="Download CV">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download CV
            </a>
          </div>
        </div>
        <img
          src="/headshot.jpg"
          alt="George Lennox"
          class="hero-photo"
          width="200"
          height="267"
        />
      </section>

      <!-- Experience -->
      <section id="experience" class="section">
        <h2 class="section-label">Experience</h2>
        <div class="portfolio-grid">
          {experience.map((item) => (
            <article class="card">
              <div class="card-header">
                <h3 class="card-company">{item.company}</h3>
                <span class="card-period">{item.period}</span>
              </div>
              <p class="card-role">{item.role}</p>
              <ul class="card-bullets">
                {item.bullets.map((bullet) => (
                  <li class="card-bullet">{bullet}</li>
                ))}
              </ul>
              <div class="card-footer">
                <a href={`/experience/${item.slug}`} class="card-arrow" aria-label={`View ${item.company} in detail`}>
                  View more →
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section id="skills" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Skills</h2>
          </div>
          <div class="skills-tags">
            <span class="skill-tag">Strategic Partnerships & Ecosystem Growth</span>
            <span class="skill-tag">Customer Success & Client Retention</span>
            <span class="skill-tag">AI Adoption & Workflow Automation</span>
            <span class="skill-tag">Executive Operations & Chief of Staff</span>
            <span class="skill-tag">Data Analytics & Executive Reporting</span>
            <span class="skill-tag">Programme & Portfolio Leadership</span>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">About</h2>
          </div>
          <div class="about-text">
            <p>
              I have over 10 years of experience leading customer relationships,
              strategic initiatives, and transformation programmes across fintech,
              Web3, and enterprise technology.
            </p>
            <p>
              Most recently, I led strategic partnerships and ecosystem growth at
              SideShift.ai. Prior to that, I served as Chief of Staff to programme
              leadership at Accenture on a major FTSE 100 transformation programme
              for Kingfisher Group, acting as the bridge between executive stakeholders
              and delivery teams.
            </p>
            <p>
              My background combines customer success, partnerships, programme
              leadership, and enterprise consulting — with a strong track record of
              growing accounts, delivering complex initiatives, and building trusted
              stakeholder relationships.
            </p>
            <p>Based in London, UK. Open to remote and hybrid opportunities.</p>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="section">
        <div class="sidebar-layout">
          <div>
            <h2 class="section-label">Contact</h2>
          </div>
          <div class="contact-groups">
            <div class="contact-group">
              <p class="contact-group-label">Direct</p>
              <nav class="contact-links" aria-label="Direct contact">
                <a href="mailto:gwhlennox@gmail.com">gwhlennox@gmail.com ↗</a>
                <a href="https://wa.me/447792304894" target="_blank" rel="noopener noreferrer">WhatsApp ↗</a>
                <a href="https://t.me/devmetalguy" target="_blank" rel="noopener noreferrer">Telegram ↗</a>
              </nav>
            </div>
            <div class="contact-group">
              <p class="contact-group-label">Follow</p>
              <nav class="contact-links" aria-label="Social links">
                <a href="https://www.linkedin.com/in/georgelennox/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
                <a href="https://github.com/gwhlennox" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
                <!-- TODO: add X handle -->
                <a href="https://x.com/YOUR_HANDLE" target="_blank" rel="noopener noreferrer">X ↗</a>
              </nav>
            </div>
            <div class="contact-group">
              <p class="contact-group-label">Schedule</p>
              <nav class="contact-links" aria-label="Schedule">
                <a href="https://calendar.app.google/3KUytQbxjpXJnTed8" target="_blank" rel="noopener noreferrer">Book a meeting ↗</a>
              </nav>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span>© 2026 George Lennox</span>
        <span>London, UK</span>
      </div>
    </footer>

  </body>
</html>
