            <div>
              <div class="flex items-baseline justify-between gap-4 mb-1">
                <span class="text-sm font-medium text-neutral-900">{item.company}</span>
                <span class="text-xs text-neutral-300 shrink-0 tabular-nums">{item.period}</span>
              </div>
              <p class="text-xs text-neutral-400 mb-2">{item.role}</p>
              <p class="text-sm text-neutral-400 leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Media -->
      <section id="media" class="mb-16">
        <h2 class="text-xs uppercase tracking-widest text-neutral-300 mb-8">Media</h2>
