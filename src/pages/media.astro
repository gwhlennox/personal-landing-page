---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

const videos = [
  { id: 'hYJDdbg35SI' },
  { id: 'lreyNaTfQuw' },
  { id: 'OeqitXX0pfE' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Media — George Lennox</title>
    <meta name="description" content="Video interviews and media appearances by George Lennox on Web3, partnerships, and enterprise strategy." />
    <link rel="canonical" href="https://georgelennox.xyz/media" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://georgelennox.xyz/media" />
    <meta property="og:title" content="Media — George Lennox" />
    <meta property="og:description" content="Video interviews and media appearances by George Lennox on Web3, partnerships, and enterprise strategy." />
    <meta property="og:image" content="https://georgelennox.xyz/headshot.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@winwithgeorge" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>

  <body>

    <nav class="nav">
<div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="Back to home">
          <img src="/headshot.jpg" alt="George Lennox" class="nav-avatar" width="30" height="30" />
        </a>
        <div class="nav-links">
          <a href="/#experience">Experience</a>
          <a href="/media">Media</a>
          <a href="/#about">About</a>
          <a href="/#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main class="container">
      <div class="standalone-page">

        <a href="/" class="back-link">← Home</a>

        <header class="standalone-header">
          <p class="hero-label">Appearances</p>
          <h1 class="standalone-title">Media</h1>
          <p class="standalone-subtitle">Interviews and features across Web3, partnerships, and enterprise strategy.</p>
        </header>

        <div class="videos-grid">
          {videos.map((video) => (
            <div class="video-item">
              <div class="video-embed">
                <iframe
                  src={`https://www.youtube.com/embed/${video.id}`}
                  title="Video appearance"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          ))}
        </div>

      </div>
    </main>

    <Footer />

  </body>
</html>
